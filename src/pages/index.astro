---
// src/pages/index.astro
// Use the relative path from the public folder
const bgImage = "/images/coming-soon-bg.jpg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Latinos In The USA — Coming Soon</title>
    <style define:vars={{ bgImage: `url("${bgImage}")` }}>
      :root {
        --bg: #0b0907;
        --bg-soft: #15110d;
        --cream: #efe8dd;
        --cream-dim: #cbbfae;
        --gold: #d6a33a;
        --gold-soft: #a97c25;
        --accent: #d9643a;
        --line: rgba(239, 232, 221, 0.14);
        --shadow: rgba(0, 0, 0, 0.55);
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        min-height: 100%;
        background: var(--bg);
        color: var(--cream);
        font-family: Arial, Helvetica, sans-serif;
      }

      .page {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(5, 4, 3, 0.2) 0%, rgba(5, 4, 3, 0.76) 72%, rgba(5, 4, 3, 0.95) 100%),
          radial-gradient(circle at 18% 24%, rgba(214, 163, 58, 0.18), transparent 34%),
          radial-gradient(circle at 82% 70%, rgba(217, 100, 58, 0.08), transparent 30%),
          var(--bg);
      }

      .page::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(90deg, rgba(6, 5, 4, 0.88) 0%, rgba(6, 5, 4, 0.45) 36%, rgba(6, 5, 4, 0.78) 100%),
          var(--bgImage) center center / cover no-repeat;
        filter: grayscale(16%);
        transform: scale(1.03);
        z-index: 0;
      }

      /* Rest of the CSS provided in your prompt... */
      .page::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(to right, rgba(0, 0, 0, 0.42) 0 1px, transparent 1px 100%),
          linear-gradient(to bottom, rgba(0, 0, 0, 0.18) 0 1px, transparent 1px 100%);
        background-size: 80px 80px;
        opacity: 0.08;
        mix-blend-mode: screen;
        pointer-events: none;
        z-index: 1;
      }

      .shell {
        position: relative;
        z-index: 2;
        min-height: 100vh;
        display: grid;
        grid-template-rows: auto 1fr auto;
        padding: 22px 32px 24px;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        border-bottom: 1px solid var(--line);
        padding-bottom: 14px;
      }

      .brand {
        font-size: 0.72rem;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--cream);
        font-weight: 700;
        white-space: nowrap;
      }

      .nav-note {
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--cream-dim);
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .nav-note::before {
        content: "";
        width: 42px;
        height: 1px;
        background: var(--gold);
        display: inline-block;
      }

      .hero {
        display: grid;
        align-items: end;
        grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.65fr);
        gap: 40px;
        padding: 56px 0 40px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 20px;
      }

      .eyebrow::before {
        content: "";
        width: 48px;
        height: 2px;
        background: var(--accent);
      }

      h1 {
        margin: 0;
        max-width: 10ch;
        font-size: clamp(3.6rem, 10vw, 8.5rem);
        line-height: 0.88;
        letter-spacing: -0.05em;
        text-transform: uppercase;
        font-weight: 900;
        text-wrap: balance;
      }

      h1 .accent {
        color: var(--gold);
        font-style: italic;
        font-weight: 800;
      }

      .lede {
        margin: 24px 0 0;
        max-width: 640px;
        font-size: clamp(1rem, 1.8vw, 1.2rem);
        line-height: 1.6;
        color: var(--cream-dim);
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 30px;
      }

      .btn, .ghost {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 18px;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.76rem;
        font-weight: 700;
        border: 1px solid transparent;
        transition: 180ms ease;
      }

      .btn { background: var(--accent); color: #fff; }
      .btn:hover { background: #e47249; }
      .ghost { border-color: var(--line); color: var(--cream); background: rgba(255, 255, 255, 0.02); }
      .ghost:hover { border-color: rgba(239, 232, 221, 0.28); background: rgba(255, 255, 255, 0.05); }

      .panel {
        justify-self: end;
        width: min(100%, 360px);
        border: 1px solid var(--line);
        background: linear-gradient(180deg, rgba(14, 11, 8, 0.72), rgba(14, 11, 8, 0.88));
        backdrop-filter: blur(10px);
        box-shadow: 0 30px 80px var(--shadow);
      }

      .panel-inner { padding: 28px 24px; }
      .panel-kicker { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; }
      .panel-title { margin: 0 0 12px; font-size: 1.6rem; line-height: 1.05; text-transform: uppercase; }
      .panel-copy { margin: 0; color: var(--cream-dim); line-height: 1.65; font-size: 0.96rem; }

      .stats {
        margin-top: 24px;
        padding-top: 18px;
        border-top: 1px solid var(--line);
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px 12px;
      }

      .stat-label { display: block; font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--cream-dim); margin-bottom: 6px; }
      .stat-value { font-size: 1.15rem; font-weight: 800; color: var(--cream); }

      .footer {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 24px;
        border-top: 1px solid var(--line);
        padding-top: 16px;
      }

      .quote { margin: 0 0 8px; font-family: Georgia, serif; font-size: clamp(1.15rem, 1.8vw, 1.55rem); font-style: italic; line-height: 1.35; }
      .meta { font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--cream-dim); }
      .year { font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); white-space: nowrap; }

      @media (max-width: 980px) {
        .hero { grid-template-columns: 1fr; align-items: start; padding-top: 44px; }
        .panel { justify-self: start; width: min(100%, 460px); }
        h1 { max-width: 12ch; }
      }

      @media (max-width: 640px) {
        .shell { padding: 18px 18px 20px; }
        .topbar, .footer { display: block; }
        .nav-note, .year { margin-top: 12px; }
        .hero { gap: 28px; padding: 34px 0 28px; }
        h1 { font-size: clamp(3.2rem, 16vw, 5.2rem); max-width: 8ch; }
        .lede { font-size: 0.98rem; }
        .panel-inner { padding: 22px 18px; }
        .quote { font-size: 1.08rem; }
      }
    </style>
  </head>
  <body>
    <main class="page">
      <div class="shell">
        <header class="topbar">
          <div class="brand">Latinos In The USA</div>
          <div class="nav-note">Editorial culture / history / identity</div>
        </header>

        <section class="hero">
          <div class="hero-copy">
            <div class="eyebrow">A digital home in progress</div>
            <h1>
              Stay <span class="accent">Latino.</span><br />
              Something bigger is coming.
            </h1>
            <p class="lede">
              Not a generic content dump. A sharper, cinematic platform for stories,
              memory, music, opinion, and the lived reality of Latinos in the USA.
            </p>

            <div class="actions">
              <a href="#" class="btn">Launches 2026</a>
              <a href="mailto:hello@latinosintheusa.com" class="ghost">Contact</a>
            </div>
          </div>

          <aside class="panel">
            <div class="panel-inner">
              <div class="panel-kicker">What’s coming</div>
              <h2 class="panel-title">Culture with weight.</h2>
              <p class="panel-copy">
                Original features, hot Latin music, history that matters, and a visual tone
                that feels editorial instead of disposable.
              </p>

              <div class="stats">
                <div>
                  <span class="stat-label">Focus</span>
                  <span class="stat-value">Stories</span>
                </div>
                <div>
                  <span class="stat-label">Tone</span>
                  <span class="stat-value">Bold</span>
                </div>
                <div>
                  <span class="stat-label">Built for</span>
                  <span class="stat-value">Culture</span>
                </div>
                <div>
                  <span class="stat-label">Status</span>
                  <span class="stat-value">Coming Soon</span>
                </div>
              </div>
            </div>
          </aside>
        </section>

        <footer class="footer">
          <div class="foot-copy">
            <p class="quote">
              “We are not the future of America. We are the present — and we have been the whole time.”
            </p>
            <div class="meta">LatinosInTheUSA.com / under construction</div>
          </div>
          <div class="year">2026</div>
        </footer>
      </div>
    </main>
  </body>
</html>
